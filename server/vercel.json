  {
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "dist/**"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/server.js", 
            "methods": ["GET", "PATCH" , "POST", "PUT", "DELETE", "OPTIONS"]
        }
    ]
}